---
// src/components/Services.astro — Cards Premium Responsive
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "Desenvolvimento Web",
    description: "Sistemas, APIs e landing pages com arquitetura segura e performance de ponta. React, Node.js, e tecnologias modernas."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: "Aplicações Mobile",
    description: "Apps nativos e híbridos para iOS e Android com UX fluida, intuitiva e focada em retenção de usuários."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: "Consultoria em Segurança",
    description: "Análise completa de vulnerabilidades, pentest e fortalecimento da sua infraestrutura contra ameaças digitais."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    title: "Marketing Digital",
    description: "Estratégias de growth, Meta Ads e funis de conversão para escalar sua operação e dominar o mercado digital."
  }
];
---

<section id="servicos" class="relative py-16 sm:py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 sm:mb-16" data-reveal>
      <span class="section-badge mb-4 inline-flex">Nossos Serviços</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-4">
        Soluções que <span class="text-gradient">Impulsionam</span>
      </h2>
      <p class="mt-3 sm:mt-4 text-gray-400 max-w-2xl mx-auto text-base sm:text-lg px-2">
        Do conceito à execução, oferecemos um portfólio completo de serviços para transformar seu projeto em realidade.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      {services.map((service, i) => (
        <div class="service-card" data-reveal>
          <div class="service-icon">
            <div class="w-6 h-6" set:html={service.icon} />
          </div>
          <h3 class="text-base sm:text-lg font-bold text-white mb-2 sm:mb-3">{service.title}</h3>
          <p class="text-gray-400 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
