---
// src/components/Header.astro — Navbar Premium Responsive
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500">
  <nav class="nav-container">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      <img src="/assets/logo.png" alt="Encrypted Software" class="nav-logo-img" />
      <span class="nav-logo-text">
        Encrypted<span class="text-gradient">Software</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <ul class="nav-links">
      <li><a href="#servicos">Serviços</a></li>
      <li><a href="#sobre">Sobre Nós</a></li>
      <li><a href="#contato">Contato</a></li>
    </ul>

    <!-- CTA Desktop -->
    <a href="#contato" class="nav-cta btn-primary">
      Iniciar Projeto
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>

    <!-- Mobile Hamburger -->
    <button id="menu-btn" class="hamburger-btn" aria-label="Menu" type="button">
      <span class="hamburger-box">
        <span class="hamburger-inner"></span>
      </span>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div id="menu-mobile" class="menu-overlay">
    <nav class="menu-overlay-nav">
      <a href="#servicos" class="mobile-link">Serviços</a>
      <a href="#sobre" class="mobile-link">Sobre Nós</a>
      <a href="#contato" class="mobile-link">Contato</a>
      <a href="#contato" class="mobile-link btn-primary mt-6 text-lg px-8 py-3">Iniciar Projeto</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu-mobile');
  const links = document.querySelectorAll('.mobile-link');
  const header = document.getElementById('main-header');

  const toggleMenu = () => {
    const isOpen = btn.classList.toggle('is-active');
    menu.classList.toggle('is-open');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  };

  btn.addEventListener('click', toggleMenu);
  links.forEach(link => link.addEventListener('click', () => {
    btn.classList.remove('is-active');
    menu.classList.remove('is-open');
    document.body.style.overflow = '';
  }));

  window.addEventListener('scroll', () => {
    if (window.scrollY > 80) {
      header.classList.add('header-scrolled');
    } else {
      header.classList.remove('header-scrolled');
    }
  });
</script>

<style>
  /* ══════════════════════════════
     NAV CONTAINER
     ══════════════════════════════ */
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.75rem 1rem;
  }

  @media (min-width: 640px) {
    .nav-container { padding: 0.75rem 1.5rem; }
  }
  @media (min-width: 768px) {
    .nav-container { padding: 1rem 2rem; }
  }

  /* ── Logo ── */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    z-index: 60;
  }
  .nav-logo-img {
    height: 2rem;
    transition: transform 0.3s;
  }
  .nav-logo:hover .nav-logo-img {
    transform: scale(1.05);
  }
  .nav-logo-text {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  @media (min-width: 640px) {
    .nav-logo-img { height: 2.5rem; }
    .nav-logo-text { font-size: 1.125rem; }
  }
  @media (min-width: 768px) {
    .nav-logo-img { height: 3rem; }
    .nav-logo-text { font-size: 1.25rem; }
  }

  /* ── Desktop Links — hidden on mobile ── */
  .nav-links {
    display: none;
    list-style: none;
  }
  @media (min-width: 768px) {
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .nav-links { gap: 2.5rem; }
  }
  .nav-links a {
    font-size: 0.875rem;
    color: #9ca3af;
    transition: color 0.3s;
    letter-spacing: 0.05em;
  }
  .nav-links a:hover {
    color: #ffffff;
  }

  /* ── CTA Button — hidden on mobile ── */
  .nav-cta {
    display: none;
    font-size: 0.75rem;
    padding: 0.625rem 1.25rem;
  }
  @media (min-width: 768px) {
    .nav-cta {
      display: inline-flex;
    }
  }

  /* ── Header scroll state ── */
  .header-scrolled {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* ══════════════════════════════
     HAMBURGER — visible only on mobile
     ══════════════════════════════ */
  .hamburger-btn {
    position: relative;
    z-index: 60;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  /* HIDE on desktop */
  @media (min-width: 768px) {
    .hamburger-btn {
      display: none !important;
    }
  }

  .hamburger-box {
    position: relative;
    width: 24px;
    height: 18px;
    display: block;
  }

  .hamburger-inner,
  .hamburger-inner::before,
  .hamburger-inner::after {
    position: absolute;
    width: 24px;
    height: 2px;
    background-color: #d1d5db;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger-inner {
    top: 50%;
    transform: translateY(-50%);
  }

  .hamburger-inner::before {
    content: '';
    top: -7px;
    left: 0;
  }

  .hamburger-inner::after {
    content: '';
    bottom: -7px;
    left: 0;
    width: 16px;
  }

  /* ── Active: X ── */
  .hamburger-btn.is-active .hamburger-inner {
    background-color: transparent;
  }
  .hamburger-btn.is-active .hamburger-inner::before {
    top: 0;
    transform: rotate(45deg);
    background-color: #f87171;
  }
  .hamburger-btn.is-active .hamburger-inner::after {
    bottom: 0;
    width: 24px;
    transform: rotate(-45deg);
    background-color: #f87171;
  }

  /* ══════════════════════════════
     MOBILE MENU OVERLAY
     ══════════════════════════════ */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 55;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s ease, visibility 0.35s ease;
  }
  .menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  /* Hide overlay on desktop always */
  @media (min-width: 768px) {
    .menu-overlay {
      display: none !important;
    }
  }

  .menu-overlay-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 2rem;
    padding: 1.5rem;
  }

  .mobile-link {
    font-size: 1.5rem;
    font-weight: 300;
    color: #d1d5db;
    transition: color 0.3s, opacity 0.3s, transform 0.3s;
    opacity: 0;
    transform: translateY(20px);
  }
  .mobile-link:hover {
    color: #ef4444;
  }

  .menu-overlay.is-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }
  .menu-overlay.is-open .mobile-link:nth-child(1) { transition-delay: 0.1s; }
  .menu-overlay.is-open .mobile-link:nth-child(2) { transition-delay: 0.15s; }
  .menu-overlay.is-open .mobile-link:nth-child(3) { transition-delay: 0.2s; }
  .menu-overlay.is-open .mobile-link:nth-child(4) { transition-delay: 0.3s; }
</style>
