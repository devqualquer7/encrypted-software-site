---
// src/components/Gateway.astro — Premium Gateway + Stats + Awards Responsive
const stats = [
  { value: "99.99%", label: "Uptime Garantido", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>` },
  { value: "< 200ms", label: "Velocidade Média", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>` },
  { value: "API RESTful", label: "Integração Completa", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>` }
];

const awards = [
  { imgSrc: "/assets/100k.png", alt: "Placa de 100 mil faturados", label: "100K+" },
  { imgSrc: "/assets/500k.png", alt: "Placa de 500 mil faturados", label: "500K+" },
  { imgSrc: "/assets/1M.png", alt: "Placa de 1 milhão faturados", label: "1M+" }
];
---

<section id="gateway" class="relative py-16 sm:py-24 md:py-32 overflow-hidden">
  <div class="grid-pattern absolute inset-0 opacity-20"></div>
  <div class="glow-orb-red absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] sm:w-[600px] md:w-[800px] h-[200px] sm:h-[300px] md:h-[400px] opacity-10"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <!-- Gateway Section -->
    <div class="text-center mb-10 sm:mb-16 animate-on-scroll">
      <span class="section-badge mb-4 inline-flex">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
        Gateway de Pagamentos
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-4">
        Robusto e <span class="text-gradient">Escalável</span>
      </h2>
      <p class="mt-3 sm:mt-4 text-gray-400 max-w-2xl mx-auto text-base sm:text-lg px-2">
        Nossa gateway proprietária processa transações com máxima segurança e performance, impulsionando o crescimento de nossos parceiros.
      </p>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 mb-16 sm:mb-24 animate-on-scroll animate-delay-1">
      {stats.map(stat => (
        <div class="stat-card">
          <div class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center mx-auto mb-3 sm:mb-4 text-red-400" set:html={stat.icon} />
          <p class="stat-number mb-2">{stat.value}</p>
          <p class="text-gray-400 text-sm">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Awards / Milestones Section -->
    <div class="text-center mb-10 sm:mb-16 animate-on-scroll">
      <span class="section-badge mb-4 inline-flex">Nossas Conquistas</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mt-4">
        Resultados que <span class="text-gradient">Falam por Si</span>
      </h2>
      <p class="mt-3 sm:mt-4 text-gray-400 max-w-2xl mx-auto text-base sm:text-lg px-2">
        Um histórico comprovado de sucesso, segurança e crescimento para todos os nossos clientes.
      </p>
    </div>

    <!-- Award Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 md:gap-8">
      {awards.map((award, i) => (
        <div class={`award-card animate-on-scroll animate-delay-${i + 1}`}>
          <img
            src={award.imgSrc}
            alt={award.alt}
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
